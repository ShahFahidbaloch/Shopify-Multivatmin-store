{% schema %}
{
  "name": "Comparison Table",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "GOOD HEALTH MADE EASY"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How Multivitamin Compares"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "image_picker",
      "id": "our_logo",
      "label": "Our Logo"
    },
    {
      "type": "image_picker",
      "id": "competitor_logo",
      "label": "Competitor Logo"
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Comparison Row",
      "settings": [
        {
          "type": "text",
          "id": "attribute",
          "label": "Attribute",
          "default": "Protein"
        },
        {
          "type": "text",
          "id": "our_value",
          "label": "Our Value",
          "info": "Use 'check' or 'cross' for icons",
          "default": "12-14g"
        },
        {
          "type": "text",
          "id": "competitor_value",
          "label": "Competitor Value",
          "info": "Use 'check' or 'cross' for icons",
          "default": "2-4g"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Comparison Table",
      "blocks": [
        { "type": "row", "settings": { "attribute": "Protein", "our_value": "12-14g", "competitor_value": "2-4g" } },
        { "type": "row", "settings": { "attribute": "Sugar", "our_value": "0g", "competitor_value": "2g" } },
        { "type": "row", "settings": { "attribute": "Net Carbs", "our_value": "6-8g", "competitor_value": "6-8g" } },
        { "type": "row", "settings": { "attribute": "High Fibre", "our_value": "check", "competitor_value": "check" } },
        { "type": "row", "settings": { "attribute": "Grain Free", "our_value": "check", "competitor_value": "cross" } },
        { "type": "row", "settings": { "attribute": "Gluten Free", "our_value": "check", "competitor_value": "cross" } },
        { "type": "row", "settings": { "attribute": "Vegan", "our_value": "check", "competitor_value": "cross" } }
      ]
    }
  ]
}
{% endschema %}

<section class="ecb-section  ecb-mobile-template-one ecb-defaultwidth no-mask" style="background-color: {{ section.settings.bg_color }}; padding: 100px 0;">
  <div class="page-width">
    
    <div class="uk-text-center mb-16" uk-scrollspy="cls: uk-animation-slide-bottom; repeat: false;">
      {% if section.settings.tagline != blank %}
        <p class="tagline font-semibold text-sm mb-2" style="letter-spacing: 2px; color: #8BA0B0;">
          {{ section.settings.tagline }}
        </p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="uk-h2 uk-margin-remove-top h2-responsive font-medium" style="color: #1A1A1A; line-height: 1.1;">
          {{ section.settings.heading }}
        </h2>
      {% endif %}
    </div>

    <div class="uk-overflow-auto" uk-scrollspy="cls: uk-animation-slide-bottom; delay: 200; repeat: false;">
      <table class="uk-table uk-text-center uk-table-divider uk-table-middle comparison-table" style="font-family: 'Inter', sans-serif;">
        <thead>
          <tr>
            <th style="width: 33%; border-bottom: none;">&nbsp;</th>
            <th class="primary-column uk-transition-toggle" style="width: 34%; background: #F9F8F6; border-top-left-radius: 24px; border-top-right-radius: 24px; padding: 40px 20px;">
              {% if section.settings.our_logo != blank %}
                {{ section.settings.our_logo | image_url: width: 200 | image_tag: class: 'uk-display-inline uk-transition-scale-up uk-transition-opaque', style: 'max-height: 80px; width: auto;' }}
              {% else %}
                <img src="{{ 'logo2.png' | asset_url }}" class="uk-display-inline uk-transition-scale-up uk-transition-opaque" alt="Us" width="80" height="auto" style="max-height: 80px; width: auto;">
              {% endif %}
            </th>
            <th class="uk-transition-toggle" style="width: 33%; padding: 40px 20px;">
              {% if section.settings.competitor_logo != blank %}
                {{ section.settings.competitor_logo | image_url: width: 200 | image_tag: class: 'uk-display-inline uk-transition-scale-up uk-transition-opaque', style: 'max-height: 80px; width: auto;' }}
              {% else %}
                <img src="{{ 'logo5.png' | asset_url }}" class="uk-display-inline uk-transition-scale-up uk-transition-opaque" alt="Them" width="80" height="auto" style="max-height: 80px; width: auto;">
              {% endif %}
            </th>
          </tr>
        </thead>
        <tbody>
          {% for block in section.blocks %}
            <tr {{ block.shopify_attributes }}>
              <th class="uk-text-left font-semibold" style="padding: 24px 20px 24px 40px; color: #1A1A1A; font-size: 16px;">{{ block.settings.attribute }}</th>
              <td class="primary-column font-bold" style="background: #F9F8F6; padding: 24px 20px; color: #1A1A1A; border-bottom: 1px solid rgba(0,0,0,0.05); font-size: 16px;">
                {% if block.settings.our_value == 'check' %}
                  <div class="flex justify-center"><img src="{{ 'patch-check-green.svg' | asset_url }}" alt="Check" width="24" height="24"></div>
                {% elsif block.settings.our_value == 'cross' %}
                  <div class="flex justify-center"><img src="{{ 'x-circle-red.svg' | asset_url }}" alt="Cross" width="24" height="24"></div>
                {% else %}
                  {{ block.settings.our_value }}
                {% endif %}
              </td>
              <td style="padding: 24px 20px; color: #4A5A6A; font-size: 16px;">
                {% if block.settings.competitor_value == 'check' %}
                  <div class="flex justify-center"><img src="{{ 'patch-check-green.svg' | asset_url }}" alt="Check" width="24" height="24"></div>
                {% elsif block.settings.competitor_value == 'cross' %}
                  <div class="flex justify-center"><img src="{{ 'x-circle-red.svg' | asset_url }}" alt="Cross" width="24" height="24"></div>
                {% else %}
                  {{ block.settings.competitor_value }}
                {% endif %}
              </td>
            </tr>
          {% endfor %}
        </tbody>
        <tfoot>
          <tr>
            <td style="border-top: none;">&nbsp;</td>
            <td class="primary-column" style="background: #F9F8F6; border-bottom-left-radius: 24px; border-bottom-right-radius: 24px; height: 40px; border-top: none;">&nbsp;</td>
            <td style="border-top: none;">&nbsp;</td>
          </tr>
        </tfoot>
      </table>
    </div>

  </div>
</section>

<style>
  .comparison-table {
    border-collapse: separate;
    border-spacing: 0;
  }
  .comparison-table tr th {
    border-bottom: 1px solid #EAEAEA;
  }
  .comparison-table tr:last-child th {
    border-bottom: none;
  }
  .tagline {
    text-transform: uppercase;
  }
  @media screen and (max-width: 767px) {
    .uk-h2 {
      font-size: 32px !important;
    }
    .comparison-table th, .comparison-table td {
      padding: 15px 10px !important;
      font-size: 13px !important;
    }
  }
</style>
