{% schema %}
{
  "name": "FAQ Section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Answered by Doctors and Scientists"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F9F8F6"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What are the best multivitamins for my health?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Donec mattis erat tellus. Pellentesque ac urna vitae risus tincidunt aliquet at at erat. Donec pretium sodales ipsum, sit amet commodo lacus viverra ac.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Section",
      "blocks": [
        { "type": "faq_item", "settings": { "question": "What are the best multivitamins for my health?" } },
        { "type": "faq_item", "settings": { "question": "How do I know if I need to take multivitamin supplement?" } },
        { "type": "faq_item", "settings": { "question": "Fresh vitamin everyday" } },
        { "type": "faq_item", "settings": { "question": "Are multivitamin safe for me to use?" } }
      ]
    }
  ]
}
{% endschema %}

<section class="ecb-faq-section" style="background-color: {{ section.settings.bg_color }}; padding: 120px 0;">
  <div class="page-width">
    
    <div class="faq-container">
      
      <!-- Left Column: Heading -->
      <div class="faq-header-col">
        {% if section.settings.heading != blank %}
          <h2 class="faq-main-heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.subheading != blank %}
          <p class="faq-subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>

      <!-- Right Column: Accordion -->
      <div class="faq-content-col">
        <ul uk-accordion="collapsible: true" class="uk-accordion custom-faq-accordion">
          {% for block in section.blocks %}
            <li {{ block.shopify_attributes }}>
              <a class="uk-accordion-title accordion-q" href="#">
                {{ block.settings.question }}
              </a>
              <div class="uk-accordion-content accordion-a">
                {{ block.settings.answer }}
              </div>
            </li>
          {% endfor %}
        </ul>
      </div>

    </div>

  </div>
</section>

<style>
  .ecb-faq-section {
    width: 100%;
    overflow: hidden;
  }
  .ecb-faq-section .faq-container {
    display: flex;
    align-items: flex-start;
    gap: 80px;
  }
  .ecb-faq-section .faq-header-col {
    flex: 0 0 35%;
    max-width: 35%;
  }
  .ecb-faq-section .faq-content-col {
    flex: 0 0 65%;
    max-width: 65%;
  }

  .ecb-faq-section .faq-main-heading {
    font-size: 28px;
    font-weight: 600;
    color: #1A1A1A;
    line-height: 1.2;
    margin: 0 0 16px 0;
    letter-spacing: -0.2px;
  }
  .ecb-faq-section .faq-subheading {
    font-size: 15px;
    color: #6C6C6C;
    margin: 0;
    line-height: 1.5;
  }

  /* Accordion Styling */
  .custom-faq-accordion {
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .custom-faq-accordion li {
    border-bottom: 1px solid #EAEAEA;
    margin: 0;
  }
  .custom-faq-accordion li:first-child {
    border-top: 1px solid #EAEAEA;
  }
  
  .custom-faq-accordion .accordion-q {
    display: block;
    position: relative;
    padding: 24px 40px 24px 0;
    font-size: 15px;
    font-weight: 600;
    color: #1A1A1A;
    text-decoration: none;
    line-height: 1.4;
    transition: color 0.3s ease;
  }
  .custom-faq-accordion .accordion-q:hover {
    color: #4A4A4A;
  }

  .custom-faq-accordion .accordion-a {
    padding: 0 0 24px 0;
    font-size: 14px;
    line-height: 1.6;
    color: #4A5A6A;
  }

  /* Plus/Minus Icons */
  .custom-faq-accordion .accordion-q::before {
    content: "";
    position: absolute;
    right: 0;
    top: 50%;
    width: 14px;
    height: 14px;
    transform: translateY(-50%);
    background-image: url("data:image/svg+xml,%3Csvg width='14' height='14' viewBox='0 0 14 14' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M7 1V13M1 7H13' stroke='%231A1A1A' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-size: contain;
    background-repeat: no-repeat;
    transition: transform 0.3s ease;
  }
  .custom-faq-accordion li.uk-open .accordion-q::before {
    background-image: url("data:image/svg+xml,%3Csvg width='14' height='2' viewBox='0 0 14 2' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1H13' stroke='%231A1A1A' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
  }

  @media screen and (max-width: 959px) {
    .ecb-faq-section .faq-container {
      flex-direction: column;
      gap: 40px;
    }
    .ecb-faq-section .faq-header-col,
    .ecb-faq-section .faq-content-col {
      flex: 0 0 100%;
      max-width: 100%;
    }
    .ecb-faq-section .faq-main-heading {
      font-size: 24px;
    }
  }
</style>
