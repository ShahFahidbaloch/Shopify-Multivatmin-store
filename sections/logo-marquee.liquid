{% schema %}
{
  "name": "Logo Marquee Scroller",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_y",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Vertical Padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "speed",
      "min": 5,
      "max": 50,
      "step": 1,
      "unit": "s",
      "label": "Scrolling Speed",
      "default": 20
    },
    {
      "type": "range",
      "id": "logo_height",
      "min": 20,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Logo Height",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (Optional)"
        },
        {
          "type": "text",
          "id": "fallback_url",
          "label": "Fallback Image URL",
          "info": "Used if no file is selected. Good for demos!"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Logo Marquee Scroller",
      "blocks": [
        { "type": "logo", "settings": { "fallback_url": "//easy-content-builder-demo.myshopify.com/cdn/shop/files/logo2.png?crop=center&height=200&v=1678626780&width=200" } },
        { "type": "logo", "settings": { "fallback_url": "//easy-content-builder-demo.myshopify.com/cdn/shop/files/logo6.png?crop=center&height=200&v=1678626780&width=200" } },
        { "type": "logo", "settings": { "fallback_url": "//easy-content-builder-demo.myshopify.com/cdn/shop/files/logo3.png?crop=center&height=200&v=1678626780&width=200" } },
        { "type": "logo", "settings": { "fallback_url": "//easy-content-builder-demo.myshopify.com/cdn/shop/files/logo5.png?crop=center&height=200&v=1678626780&width=200" } },
        { "type": "logo", "settings": { "fallback_url": "//easy-content-builder-demo.myshopify.com/cdn/shop/files/logo1.png?crop=center&height=200&v=1678626614&width=200" } }
      ]
    }
  ]
}
{% endschema %}

<div class="logo-marquee-section" id="logo-marquee-{{ section.id }}" style="background-color: {{ section.settings.bg_color | default: '#ffffff' }};">
  <div class="logo-marquee-container">
    <div class="logo-marquee-track">
      
      {% comment %} 
        We use multiple repeats to ensure the scroll is perfectly seamless 
      {% endcomment %}
      {% for i in (1..4) %}
        <div class="logo-marquee-group">
          {% for block in section.blocks %}
            <div class="logo-marquee-item" {{ block.shopify_attributes }}>
              {% if block.settings.link != blank %}
                <a href="{{ block.settings.link }}" class="logo-link">
              {% endif %}
              
              {% if block.settings.image != blank %}
                {{ block.settings.image | image_url: height: 120 | image_tag: class: 'logo-img', loading: 'lazy' }}
              {% elsif block.settings.fallback_url != blank %}
                <img src="{{ block.settings.fallback_url }}" class="logo-img" alt="Brand Logo" loading="lazy">
              {% else %}
                <div class="logo-placeholder" style="height: {{ section.settings.logo_height }}px;">BRAND</div>
              {% endif %}

              {% if block.settings.link != blank %}
                </a>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      {% endfor %}

    </div>
  </div>
</div>

<style>
  #logo-marquee-{{ section.id }} {
    width: 100%;
    overflow: hidden;
    padding: 40px 0;
    border-top: 1px solid #f0f0f0;
    border-bottom: 1px solid #f0f0f0;
  }
  .logo-marquee-container {
    display: flex;
    overflow: hidden;
    width: 100%;
    position: relative;
  }
  .logo-marquee-track {
    display: flex;
    width: max-content;
    animation: marquee-scroll-right-to-left {{ section.settings.speed | default: 30 }}s linear infinite;
  }
  .logo-marquee-group {
    display: flex;
    align-items: center;
    gap: 100px; /* Space between individual logos */
    padding-right: 100px; /* Gap between groups */
  }
  .logo-marquee-item {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .logo-marquee-section .logo-img {
    height: {{ section.settings.logo_height | default: 45 }}px;
    width: auto;
    object-fit: contain;
    filter: grayscale(1);
    opacity: 0.7;
    transition: all 0.4s ease;
  }
  .logo-marquee-section .logo-img:hover {
    filter: grayscale(0);
    opacity: 1;
    transform: scale(1.05);
  }
  
  @keyframes marquee-scroll-right-to-left {
    0% { transform: translateX(0); }
    100% { transform: translateX(-25%); } /* Move by one group width (since we have 4) */
  }

  @media screen and (max-width: 767px) {
    #logo-marquee-{{ section.id }} {
      padding: 30px 0;
    }
    .logo-marquee-group {
      gap: 50px;
      padding-right: 50px;
    }
    .logo-marquee-section .logo-img {
      height: {{ section.settings.logo_height | divided_by: 1.3 | default: 35 }}px;
    }
  }
</style>
