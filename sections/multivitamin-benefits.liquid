{% schema %}
{
  "name": "Benefits Section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F9F8F6"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "OUR DIFFERENCE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Benefits for your long term health"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Multivitamins, proteins, and more are all designed to transform your health.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Side Image"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "text",
          "id": "icon_name",
          "label": "Icon Filename (SVG from assets)",
          "default": "x-diamond.svg"
        },
        {
          "type": "text",
          "id": "fallback_icon_url",
          "label": "Fallback Icon URL (for data sync)",
          "info": "Kept for legacy data compatibility."
        },
        {
          "type": "text",
          "id": "text",
          "label": "Benefit Text",
          "default": "Made in Canada"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Benefits Section",
      "blocks": [
        { "type": "benefit", "settings": { "icon_name": "x-diamond.svg", "text": "Made in Canada" } },
        { "type": "benefit", "settings": { "icon_name": "wind.svg", "text": "Vegan-friendly" } },
        { "type": "benefit", "settings": { "icon_name": "toggle-off.svg", "text": "Easy and comfortable to swallow" } },
        { "type": "benefit", "settings": { "icon_name": "check2-circle.svg", "text": "Carefully sourced and high quality components" } }
      ]
    }
  ]
}
{% endschema %}

<section class="ecb-section ecb-defaultwidth no-mask" style="background-color: {{ section.settings.bg_color }}; padding: 100px 0;">
  <div class="page-width">
    
    <div class="uk-grid uk-grid-large uk-flex-middle" uk-grid>
      
      <div class="uk-width-1-2@m" uk-scrollspy="cls: uk-animation-slide-left; repeat: false;">
        <div class="uk-inline-clip uk-transition-toggle uk-border-rounded" style="border-radius: 32px; overflow: hidden; box-shadow: 0 20px 60px rgba(0,0,0,0.06);">
          {% if section.settings.image != blank %}
            {{ section.settings.image | image_url: width: 1000 | image_tag: class: 'uk-transition-scale-up uk-transition-opaque', loading: 'lazy', style: 'width: 100%; height: auto;' }}
          {% else %}
            <!-- Legacy fallback support -->
            <img src="//easy-content-builder-demo.myshopify.com/cdn/shop/files/multivitamin_benefits.png" class="uk-transition-scale-up uk-transition-opaque" alt="Multivitamin Benefits" width="1000" height="auto" loading="lazy" style="width: 100%; height: auto;">
          {% endif %}
        </div>
      </div>

      <div class="uk-width-1-2@m" uk-scrollspy="cls: uk-animation-slide-bottom; delay: 200; repeat: false;">
        <div class="ecb-section-title mb-10">
          {% if section.settings.tagline != blank %}
            <p class="tagline font-semibold text-xs mb-3" style="letter-spacing: 2.5px; color: #6C7A89; text-transform: uppercase;">
              {{ section.settings.tagline }}
            </p>
          {% endif %}
          {% if section.settings.heading != blank %}
            <h2 class="uk-h2 uk-margin-remove-top h2-responsive font-medium" style="color: #1A1A1A;">
              {{ section.settings.heading }}
            </h2>
          {% endif %}
          {% if section.settings.description != blank %}
            <div class="description text-base mt-6" style="color: #4A5A6A; line-height: 1.6;">
              {{ section.settings.description }}
            </div>
          {% endif %}
        </div>

        <div class="uk-child-width-1-2@s uk-grid-medium uk-grid" uk-grid uk-scrollspy="cls: uk-animation-slide-bottom-small; target: .ecb-feature-item-small; delay: 300; repeat: false;">
          {% for block in section.blocks %}
            <div class="ecb-feature-item-small mb-6" {{ block.shopify_attributes }}>
              <div class="uk-grid uk-grid-small uk-flex-top" uk-grid>
                <div class="uk-width-auto">
                  <div class="p-2 bg-white rounded-lg shadow-sm">
                    {% if block.settings.icon_name != blank %}
                      <img src="{{ block.settings.icon_name | asset_url }}" alt="" width="24" height="24" style="width: 24px; height: 24px;" loading="lazy">
                    {% elsif block.settings.fallback_icon_url != blank %}
                      <img src="{{ block.settings.fallback_icon_url }}" alt="" width="24" height="24" style="width: 24px; height: 24px;" loading="lazy">
                    {% endif %}
                  </div>
                </div>
                <div class="uk-width-expand">
                  <p class="font-semibold text-sm m-0" style="color: #1A1A1A; line-height: 1.4;">{{ block.settings.text }}</p>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>

        {% if section.settings.button_label != blank %}
          <div class="mt-8">
            <a href="{{ section.settings.button_link | default: '#' }}" class="uk-button uk-button-large bg-black text-white hover:bg-gray-800 transition-colors" style="padding: 16px 48px; border-radius: 12px; font-weight: 700; text-decoration: none; display: inline-block; font-size: 14px; letter-spacing: 0.5px; text-transform: uppercase;">
              {{ section.settings.button_label }}
            </a>
          </div>
        {% endif %}
      </div>

    </div>

  </div>
</section>

<style>
  @media screen and (max-width: 959px) {
    .uk-h2 {
      font-size: 32px !important;
    }
  }
</style>
