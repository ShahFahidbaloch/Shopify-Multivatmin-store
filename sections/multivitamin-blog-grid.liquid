{% schema %}
{
  "name": "Blog Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Blogs & expert advice"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#F9F8F6"
    }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "Blog Post",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Post Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Benefit to Multivitamins"
        },
        {
          "type": "textarea",
          "id": "excerpt",
          "label": "Excerpt",
          "default": "A unique blend of ingredients that support your long-term health and wellness."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Article Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Blog Grid",
      "blocks": [
        { "type": "post", "settings": { "title": "Benefit to Multivitamins" } },
        { "type": "post", "settings": { "title": "Vitamin & Mineral Supplements" } },
        { "type": "post", "settings": { "title": "Here's why I Take A Multivitamin" } }
      ]
    }
  ]
}
{% endschema %}

<section class="ecb-blog-section" style="background-color: {{ section.settings.bg_color }}; padding: 120px 0;">
  <div class="page-width">
    
    <div class="blog-header">
      {% if section.settings.heading != blank %}
        <h2 class="blog-main-heading">{{ section.settings.heading }}</h2>
      {% endif %}
    </div>
    <div class="blog-grid">
      {% for block in section.blocks %}
        {% assign blog_index = forloop.index %}
        <div class="blog-item" {{ block.shopify_attributes }}>
          <div class="blog-card">
            <a href="{{ block.settings.link | default: '#' }}" class="blog-image-link">
              <div class="blog-image-wrapper">
                {% if block.settings.image != blank %}
                  {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy' }}
                {% else %}
                  {% capture blog_img %}multivitamin_blog{{ blog_index }}.jpg{% endcapture %}
                  <img src="{{ blog_img | asset_url }}" alt="{{ block.settings.title }}" width="600" height="auto" loading="lazy">
                {% endif %}
              </div>
            </a>

            <div class="blog-content">
              <h3 class="blog-title">
                <a href="{{ block.settings.link | default: '#' }}">{{ block.settings.title }}</a>
              </h3>
              <p class="blog-excerpt">
                {{ block.settings.excerpt }}
              </p>
              <div class="blog-footer">
                <a href="{{ block.settings.link | default: '#' }}" class="blog-btn">
                  Read Article
                </a>
              </div>
            </div>

          </div>
        </div>
      {% endfor %}
    </div>

  </div>
</section>

<style>
  .ecb-blog-section {
    width: 100%;
    overflow: hidden;
  }
  .ecb-blog-section .blog-header {
    text-align: center;
    margin-bottom: 60px;
  }
  .ecb-blog-section .blog-main-heading {
    font-size: 20px;
    font-weight: 500;
    color: #1A1A1A;
    margin: 0;
    letter-spacing: -0.2px;
  }

  .ecb-blog-section .blog-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 30px;
  }
  .ecb-blog-section .blog-item {
    flex: 0 0 calc(33.333% - 20px);
    max-width: calc(33.333% - 20px);
  }

  .ecb-blog-section .blog-card {
    background: #ffffff;
    border-radius: 20px;
    overflow: hidden;
    height: 100%;
    display: flex;
    flex-direction: column;
    box-shadow: 0 10px 40px rgba(0,0,0,0.02);
    transition: transform 0.3s ease;
  }
  .ecb-blog-section .blog-card:hover {
    transform: translateY(-8px);
  }

  .ecb-blog-section .blog-image-wrapper {
    width: 100%;
    aspect-ratio: 1.1/1;
    overflow: hidden;
  }
  .ecb-blog-section .blog-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }
  .ecb-blog-section .blog-card:hover .blog-image-wrapper img {
    transform: scale(1.05);
  }

  .ecb-blog-section .blog-content {
    padding: 30px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .ecb-blog-section .blog-title {
    font-size: 18px;
    font-weight: 500; /* NON-BOLD APPEARANCE */
    color: #1A1A1A;
    margin: 0 0 15px 0;
    line-height: 1.4;
  }
  .ecb-blog-section .blog-title a {
    text-decoration: none;
    color: inherit;
  }
  .ecb-blog-section .blog-excerpt {
    font-size: 14px;
    line-height: 1.6;
    color: #4A5A6A;
    margin: 0 0 25px 0;
  }

  .ecb-blog-section .blog-footer {
    margin-top: auto;
  }
  .ecb-blog-section .blog-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #1A1A1A;
    color: #ffffff;
    padding: 12px 28px;
    border-radius: 50px; /* PILL BUTTON */
    text-transform: uppercase;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
    text-decoration: none;
    transition: opacity 0.3s ease;
  }
  .ecb-blog-section .blog-btn:hover {
    opacity: 0.8;
  }

  @media screen and (max-width: 959px) {
    .ecb-blog-section .blog-item {
      flex: 0 0 calc(50% - 15px);
      max-width: calc(50% - 15px);
    }
  }
  @media screen and (max-width: 599px) {
    .ecb-blog-section .blog-item {
      flex: 0 0 100%;
      max-width: 100%;
    }
  }
</style>
