{% schema %}
{
  "name": "Features Grid",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "QUALITY INGREDIENTS"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Inside the Multivitamin"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card Background",
      "default": "#F9F8F6"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Card",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon Image"
        },
        {
          "type": "text",
          "id": "svg_filename",
          "label": "Local SVG Filename",
          "info": "e.g., flower2.svg. Used if no image is uploaded."
        },
        {
          "type": "text",
          "id": "text",
          "label": "Feature Title",
          "default": "Feature Default Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Feature Description",
          "default": "Write something useful to describe this section."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Features Grid",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "svg_filename": "flower2.svg",
            "text": "No Artificial Flavors",
            "description": "Clean and pure ingredients only."
          }
        },
        {
          "type": "feature",
          "settings": {
            "svg_filename": "noise-reduction.svg",
            "text": "No Synthetic Dyes",
            "description": "Natural colors derived from plants."
          }
        },
        {
          "type": "feature",
          "settings": {
            "svg_filename": "flower1.svg",
            "text": "Gluten Free & Dairy Free",
            "description": "Safe for sensitive diets."
          }
        },
        {
          "type": "feature",
          "settings": {
            "svg_filename": "brightness-low.svg",
            "text": "High protein & low sugar",
            "description": "Optimized for your energy."
          }
        },
        {
          "type": "feature",
          "settings": {
            "svg_filename": "moisture.svg",
            "text": "Non-GMO",
            "description": "Respecting nature's design."
          }
        },
        {
          "type": "feature",
          "settings": {
            "svg_filename": "shadows.svg",
            "text": "Third Party Tested",
            "description": "Verified for quality and safety."
          }
        }
      ]
    }
  ]
}
{% endschema %}

<section class="ecb-section ecb-grid ecb-template-one ecb-mobile-template-one ecb-defaultwidth no-mask" style="background-color: {{ section.settings.bg_color }}; padding: 100px 0;">
  <div class="page-width">
    
    <div class="uk-text-center mb-10" uk-scrollspy="cls: uk-animation-slide-bottom; repeat: false;">
      {% if section.settings.tagline != blank %}
        <p class="tagline font-semibold text-sm mb-2" style="letter-spacing: 2px; color: #8BA0B0;">
          {{ section.settings.tagline }}
        </p>
      {% endif %}
      {% if section.settings.title != blank %}
        <h2 class="uk-h2 uk-margin-remove-top font-medium" style="font-size: 32px; color: #1A1A1A;">
          {{ section.settings.title }}
        </h2>
      {% endif %}
    </div>

    <div class="uk-grid uk-grid-match uk-child-width-1-4@m uk-child-width-1-2@s uk-flex-center uk-grid-small" uk-grid uk-scrollspy="cls: uk-animation-slide-bottom-small; target: .ecb-feature-card; delay: 100; repeat: false;">
      {% for block in section.blocks %}
        <div class="uk-grid-margin">
          <div class="ecb-feature-card uk-card uk-card-body uk-text-center" style="background-color: {{ section.settings.card_bg }}; border-radius: 32px; padding: 40px 24px; height: 100%; display: flex; flex-direction: column; align-items: center; box-shadow: 0 4px 30px rgba(0,0,0,0.02);">
            <div class="mb-5" style="height: 60px; display: flex; align-items: center; justify-content: center;">
              {% if block.settings.icon != blank %}
                {{ block.settings.icon | image_url: width: 120 | image_tag: loading: 'lazy', style: 'max-height: 60px; width: auto;' }}
              {% elsif block.settings.svg_filename != blank %}
                <img src="{{ block.settings.svg_filename | asset_url }}" alt="{{ block.settings.text | escape }}" loading="lazy" width="60" height="60" style="max-height: 60px; width: auto;">
              {% endif %}
            </div>
            
            {% if block.settings.text != blank %}
              <h3 class="text-lg font-semibold mb-2" style="color: #1A1A1A; text-transform: none;">
                {{ block.settings.text }}
              </h3>
            {% endif %}
            
            {% if block.settings.description != blank %}
              <p class="text-sm" style="color: #5C5C5C; line-height: 1.5; margin: 0;">
                {{ block.settings.description }}
              </p>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>

  </div>
</section>

<style>
  .tagline {
    text-transform: uppercase;
  }
  .uk-grid-match > div > .uk-card {
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }
</style>
