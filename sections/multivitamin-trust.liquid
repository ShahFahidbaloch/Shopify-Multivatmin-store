{% schema %}
{
  "name": "Experts Trust",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#F9F8F6"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "INDUSTRY REVIEWS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trust by experts and doctors"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Featured Image (Side)"
    }
  ],
  "blocks": [
    {
      "type": "expert",
      "name": "Expert Review",
      "settings": [
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Avatar Image"
        },
        {
          "type": "text",
          "id": "avatar_filename",
          "label": "Avatar Filename (from assets)",
          "default": "ecb-avatar1.png"
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review Text",
          "default": "Multivitamin is the most advanced and effective supplement I've taken."
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Expert Name",
          "default": "Dr Chris Nola"
        },
        {
          "type": "text",
          "id": "author_title",
          "label": "Expert Title",
          "default": "Head of Nutrition Inc"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Experts Trust",
      "blocks": [
        { 
          "type": "expert", 
          "settings": { 
            "avatar_filename": "ecb-avatar1.png",
            "review_text": "I am so impressed with the Multivitamin. It's not surprised everyone wants one with the results so powerful.",
            "author_name": "Dr George Smith",
            "author_title": "Chief Science Officer"
          } 
        },
        { 
          "type": "expert", 
          "settings": { 
            "avatar_filename": "ecb-avatar3.png",
            "review_text": "Multivitamin is the most advanced and effective supplement I've taken.",
            "author_name": "Dr Chris Nola",
            "author_title": "Head of Nutrition Inc"
          } 
        },
        { 
          "type": "expert", 
          "settings": { 
            "avatar_filename": "ecb-avatar2.png",
            "review_text": "Each ingredient has been well tested and demonstrated its worth at the dose that's in there.",
            "author_name": "Dr Michael",
            "author_title": "Chief Science Officer"
          } 
        }
      ]
    }
  ]
}
{% endschema %}

<section class="ecb-trust-section" style="background-color: {{ section.settings.bg_color }}; padding: 120px 0;">
  <div class="page-width">
    <div class="flex-container">
      
      <!-- Left Column: Content and Marquee -->
      <div class="content-col">
        <div class="section-title">
          {% if section.settings.tagline != blank %}
            <p class="tagline">{{ section.settings.tagline }}</p>
          {% endif %}
          {% if section.settings.heading != blank %}
            <h2 class="heading">{{ section.settings.heading }}</h2>
          {% endif %}
        </div>

        <div class="marquee-container">
          <div class="marquee-track">
            {% for i in (1..3) %}
              {% for block in section.blocks %}
                <div class="testimonial-card" {{ block.shopify_attributes }}>
                  <div class="avatar-wrapper">
                    {% if block.settings.avatar != blank %}
                      {{ block.settings.avatar | image_url: width: 100 | image_tag: loading: 'lazy' }}
                    {% else %}
                      <img src="{{ block.settings.avatar_filename | asset_url }}" alt="{{ block.settings.author_name }}" width="50" height="50" loading="lazy">
                    {% endif %}
                  </div>
                  <div class="testimonial-content">
                    <p class="review-text">"{{ block.settings.review_text }}"</p>
                    <p class="author-info">
                      <span class="author-name">-- {{ block.settings.author_name }}</span>, 
                      <span class="author-title">{{ block.settings.author_title }}</span>
                    </p>
                  </div>
                </div>
              {% endfor %}
            {% endfor %}
          </div>
        </div>
      </div>

      <!-- Right Column: Image -->
      <div class="image-col">
        <div class="image-wrapper">
          {% if section.settings.main_image != blank %}
            {{ section.settings.main_image | image_url: width: 1400 | image_tag: loading: 'lazy' }}
          {% else %}
            <img src="https://easy-content-builder-demo.myshopify.com/cdn/shop/files/multivitamin_section_3.jpg" alt="Experts Trust" width="1200" height="auto" loading="lazy">
          {% endif %}
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .ecb-trust-section {
    overflow: hidden;
    position: relative;
    width: 100%;
  }
  .ecb-trust-section .flex-container {
    display: flex;
    align-items: center;
    gap: 60px;
  }
  .ecb-trust-section .content-col {
    flex: 0 0 50%;
    max-width: 50%;
  }
  .ecb-trust-section .image-col {
    flex: 0 0 calc(50% - 60px);
    max-width: calc(50% - 60px);
  }

  .ecb-trust-section .section-title .tagline {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 2.5px;
    color: #6C7A89;
    text-transform: uppercase;
    margin-bottom: 20px;
  }
  .ecb-trust-section .section-title .heading {
    font-size: 56px;
    line-height: 1.1;
    font-weight: 500;
    color: #1A1A1A;
    margin: 0 0 50px 0;
  }

  .ecb-trust-section .marquee-container {
    position: relative;
    width: 100%;
    overflow: hidden;
    padding: 20px 0;
    mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
  }
  .ecb-trust-section .marquee-track {
    display: flex;
    width: max-content;
    animation: scrollHorizontalTrust 30s linear infinite;
  }
  .ecb-trust-section .marquee-track:hover {
    animation-play-state: paused;
  }

  .ecb-trust-section .testimonial-card {
    flex: 0 0 280px;
    width: 280px;
    margin-right: 40px;
    text-align: left;
  }
  .ecb-trust-section .avatar-wrapper {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    overflow: hidden;
    margin-bottom: 20px;
  }
  .ecb-trust-section .avatar-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .ecb-trust-section .review-text {
    font-size: 15px;
    line-height: 1.6;
    color: #1A1A1A;
    font-weight: 500;
    margin-bottom: 12px;
  }
  .ecb-trust-section .author-info {
    font-size: 13px;
    color: #6C7A89;
    margin: 0;
  }
  .ecb-trust-section .author-name {
    color: #1A1A1A;
    font-weight: 700;
  }

  .ecb-trust-section .image-wrapper {
    border-radius: 40px;
    overflow: hidden;
    box-shadow: 0 40px 100px rgba(0,0,0,0.08);
  }
  .ecb-trust-section .image-wrapper img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.6s ease;
  }
  .ecb-trust-section .image-wrapper:hover img {
    transform: scale(1.05);
  }

  @keyframes scrollHorizontalTrust {
    0% { transform: translateX(0); }
    100% { transform: translateX(calc(-320px * {{ section.blocks.size }} )); }
  }

  @media screen and (max-width: 959px) {
    .ecb-trust-section .flex-container {
      flex-direction: column;
      gap: 40px;
    }
    .ecb-trust-section .content-col,
    .ecb-trust-section .image-col {
      flex: 0 0 100%;
      max-width: 100%;
    }
    .ecb-trust-section .section-title .heading {
      font-size: 36px;
    }
  }
</style>
