{% schema %}
{
  "name": "Featured Buy Section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Select Product"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Custom Image",
      "info": "Overrides product featured image"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "GOOD HEALTH MADE EASY"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Multivitamin"
    },
    {
      "type": "text",
      "id": "price",
      "label": "Price Text",
      "default": "$199.00 USD"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>A unique blend of ingredients that support your long-term health and wellness.</p>"
    },
    {
      "type": "text",
      "id": "guarantee_text",
      "label": "Guarantee Text",
      "default": "30-DAY MONEY BACK GUARANTEE"
    },
    {
      "type": "text",
      "id": "shipping_text",
      "label": "Shipping Text",
      "default": "FREE SHIPPING ON ORDERS OVER $99"
    }
  ],
  "presets": [
    {
      "name": "Featured Buy Section"
    }
  ]
}
{% endschema %}

{%- liquid
  assign product = section.settings.product
  assign title = section.settings.title
  assign price = section.settings.price
  assign image = section.settings.image

  if product != blank
    assign title = product.title
    assign price = product.price | money_with_currency
    assign image = product.featured_image
  endif
-%}

<section class="ecb-featured-buy" style="background-color: #ffffff; padding: 100px 0;">
  <div class="page-width">
    <div class="flex-container">
      
      <!-- Product Image -->
      <div class="image-col">
        <div class="image-wrapper">
          {% if image != blank %}
            {{ image | image_url: width: 1200 | image_tag: loading: 'lazy' }}
          {% else %}
            <img src="{{ 'multivitamin.jpg' | asset_url }}" alt="{{ title }}" width="1000" height="auto" loading="lazy">
          {% endif %}
        </div>
      </div>

      <!-- Product Details -->
      <div class="details-col">
        <div class="product-info">
          {% if section.settings.tagline != blank %}
            <p class="tagline">{{ section.settings.tagline }}</p>
          {% endif %}
          <h2 class="title">{{ title }}</h2>
          <div class="price">{{ price }}</div>
          <div class="description">
            {{ section.settings.description }}
          </div>
        </div>

        <div class="purchase-form">
          <div class="quantity-wrapper">
            <label class="quantity-label">Quantity</label>
            <div class="quantity-selector">
              <button type="button" class="qty-btn" onclick="let input = this.parentNode.querySelector('input'); input.stepDown();">-</button>
              <input type="number" value="1" min="1" class="qty-input">
              <button type="button" class="qty-btn" onclick="let input = this.parentNode.querySelector('input'); input.stepUp();">+</button>
            </div>
          </div>

          <div class="button-group">
            <button class="btn btn-secondary">Add to cart</button>
            <button class="btn btn-primary">Buy it now</button>
          </div>

          <div class="trust-badges">
            <div class="badge-item">
              <div class="badge-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 4v6h-6"></path><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path></svg>
              </div>
              <span class="badge-text">{{ section.settings.guarantee_text }}</span>
            </div>
            <div class="badge-item">
              <div class="badge-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
              </div>
              <span class="badge-text">{{ section.settings.shipping_text }}</span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .ecb-featured-buy {
    width: 100%;
    overflow: hidden;
  }
  .ecb-featured-buy .flex-container {
    display: flex;
    align-items: center;
    gap: 80px;
  }
  .ecb-featured-buy .image-col, 
  .ecb-featured-buy .details-col {
    flex: 0 0 50%;
    max-width: 50%;
  }

  .ecb-featured-buy .image-wrapper {
    border-radius: 40px;
    overflow: hidden;
    box-shadow: 0 40px 100px rgba(0,0,0,0.06);
  }
  .ecb-featured-buy .image-wrapper img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ecb-featured-buy .tagline {
    font-size: 13px;
    font-weight: 600;
    color: #8BA0B0;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 15px;
  }
  .ecb-featured-buy .title {
    font-size: 64px;
    font-weight: 600;
    color: #1A1A1A;
    margin: 0;
    line-height: 1.1;
  }
  .ecb-featured-buy .price {
    font-size: 28px;
    font-weight: 500;
    color: #1A1A1A;
    margin-top: 20px;
  }
  .ecb-featured-buy .description {
    font-size: 16px;
    line-height: 1.6;
    color: #4A5A6A;
    margin-top: 25px;
    max-width: 500px;
  }

  .ecb-featured-buy .quantity-wrapper {
    margin-top: 40px;
  }
  .ecb-featured-buy .quantity-label {
    display: block;
    font-size: 14px;
    font-weight: 600;
    color: #1A1A1A;
    margin-bottom: 12px;
  }
  .ecb-featured-buy .quantity-selector {
    display: inline-flex;
    align-items: center;
    border: 1px solid #1A1A1A;
    height: 56px;
  }
  .ecb-featured-buy .qty-btn {
    background: transparent;
    border: none;
    width: 56px;
    height: 100%;
    cursor: pointer;
    font-size: 20px;
    color: #1A1A1A;
  }
  .ecb-featured-buy .qty-input {
    border: none;
    width: 60px;
    text-align: center;
    font-size: 16px;
    font-weight: 600;
    color: #1A1A1A;
    background: transparent;
  }
  .ecb-featured-buy .qty-input::-webkit-outer-spin-button,
  .ecb-featured-buy .qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .ecb-featured-buy .button-group {
    margin-top: 25px;
    display: flex;
    flex-direction: column;
    gap: 15px;
  }
  .ecb-featured-buy .btn {
    width: 100%;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    border-radius: 0 !important; /* FORCED SQUARE */
  }
  .ecb-featured-buy .btn-secondary {
    background: #ffffff;
    color: #1A1A1A;
    border: 1px solid #1A1A1A;
  }
  .ecb-featured-buy .btn-primary {
    background: #1A1A1A;
    color: #ffffff;
    border: none;
  }
  .ecb-featured-buy .btn:hover {
    opacity: 0.8;
  }

  .ecb-featured-buy .trust-badges {
    margin-top: 40px;
    display: flex;
    flex-direction: column;
    gap: 15px;
  }
  .ecb-featured-buy .badge-item {
    display: flex;
    align-items: center;
    gap: 15px;
  }
  .ecb-featured-buy .badge-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: #1A1A1A;
  }
  .ecb-featured-buy .badge-text {
    font-size: 14px;
    font-weight: 600;
    color: #1A1A1A;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  @media screen and (max-width: 959px) {
    .ecb-featured-buy .flex-container {
      flex-direction: column;
      gap: 40px;
    }
    .ecb-featured-buy .image-col, 
    .ecb-featured-buy .details-col {
      flex: 0 0 100%;
      max-width: 100%;
    }
    .ecb-featured-buy .title {
      font-size: 40px;
    }
  }
</style>
