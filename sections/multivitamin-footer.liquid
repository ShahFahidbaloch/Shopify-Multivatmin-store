{% schema %}
{
  "name": "Custom Footer",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter Heading",
      "default": "Subscribe to our emails"
    },
    {
      "type": "checkbox",
      "id": "show_powered_by",
      "label": "Show 'Powered by Shopify'",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Quick links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Select Menu"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Our mission"
        },
        {
          "type": "richtext",
          "id": "subtext",
          "label": "Text",
          "default": "<p>Share contact information, store details, and brand content with your customers.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Footer"
    }
  ]
}
{% endschema %}

<footer class="multivitamin-footer" style="background-color: {{ section.settings.bg_color }};">
  <div class="page-width">
    
    <!-- Top Content: 3 Columns -->
    <div class="footer-top-grid">
      {% for block in section.blocks %}
        <div class="footer-block" {{ block.shopify_attributes }}>
          {% if block.settings.heading != blank %}
            <h2 class="footer-block-heading">{{ block.settings.heading }}</h2>
          {% endif %}

          {% case block.type %}
            {% when 'link_list' %}
              {% if block.settings.menu != blank %}
                <ul class="footer-list">
                  {% for link in block.settings.menu.links %}
                    <li>
                      <a href="{{ link.url }}" class="footer-link">{{ link.title }}</a>
                    </li>
                  {% endfor %}
                </ul>
              {% else %}
                <!-- Mock Links for Demo if no menu selected -->
                <ul class="footer-list">
                  <li><a href="#" class="footer-link">Search</a></li>
                  <li><a href="#" class="footer-link">Contact</a></li>
                </ul>
              {% endif %}

            {% when 'text' %}
              <div class="footer-text-content">
                {{ block.settings.subtext }}
              </div>
          {% endcase %}
        </div>
      {% endfor %}
    </div>

    <!-- Middle: Centered Newsletter -->
    <div class="footer-newsletter">
      {% if section.settings.newsletter_heading != blank %}
        <h2 class="newsletter-heading">{{ section.settings.newsletter_heading }}</h2>
      {% endif %}
      
      {% form 'customer', class: 'footer-newsletter-form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="newsletter-input-group">
          <input
            type="email"
            name="contact[email]"
            class="newsletter-input"
            value="{{ form.email }}"
            placeholder="Email"
            required
          >
          <button type="submit" class="newsletter-submit" aria-label="Subscribe">
            <svg viewBox="0 0 14 10" fill="none" aria-hidden="true" focusable="false" role="presentation" class="icon icon-arrow" xmlns="http://www.w3.org/2000/svg">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M8.537.808a.5.5 0 01.817-.162l4 4a.5.5 0 010 .708l-4 4a.5.5 0 11-.708-.708L11.793 5.5H1a.5.5 0 010-1h10.793L8.646 1.354a.5.5 0 01-.109-.546z" fill="currentColor">
            </svg>
          </button>
        </div>
        {% if form.posted_successfully? %}
          <p class="newsletter-success">Thanks for subscribing!</p>
        {% endif %}
      {% endform %}
    </div>

    <!-- Bottom: Copyright Bar -->
    <div class="footer-bottom">
      <div class="footer-copyright">
        &copy; {{ 'now' | date: '%Y' }}, {{ shop.name | link_to: routes.root_url }}
        {% if section.settings.show_powered_by %}
          {{ powered_by_link }}
        {% endif %}
      </div>
    </div>

  </div>
</footer>

<style>
  .multivitamin-footer {
    padding: 100px 0 40px;
    font-family: 'Inter', sans-serif;
    border-top: 1px solid #EDEDED;
    border-bottom: 20px solid #E6EEF2; /* Matching the bottom margin/spacing in design */
  }

  .footer-top-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
    margin-bottom: 60px;
  }

  .footer-block-heading {
    font-size: 20px;
    font-weight: 600;
    color: #1A1A1A;
    margin: 0 0 24px 0;
  }

  .footer-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-list li {
    margin-bottom: 12px;
  }

  .footer-link {
    text-decoration: none;
    color: #6C6C6C;
    font-size: 15px;
    transition: color 0.2s ease;
  }

  .footer-link:hover {
    color: #000;
  }

  .footer-text-content {
    font-size: 15px;
    line-height: 1.6;
    color: #6C6C6C;
    max-width: 320px;
  }

  /* Newsletter Styles */
  .footer-newsletter {
    text-align: center;
    max-width: 450px;
    margin: 0 auto 60px;
  }

  .newsletter-heading {
    font-size: 22px;
    font-weight: 600;
    color: #1A1A1A;
    margin: 0 0 24px 0;
  }

  .newsletter-input-group {
    position: relative;
    border: 1px solid #000000;
    border-radius: 4px;
    display: flex;
    overflow: hidden;
  }

  .newsletter-input {
    width: 100%;
    border: none;
    padding: 14px 20px;
    font-size: 15px;
    color: #1A1A1A;
    outline: none;
  }

  .newsletter-submit {
    background: none;
    border: none;
    padding: 0 20px;
    cursor: pointer;
    color: #1A1A1A;
    display: flex;
    align-items: center;
    border-left: 1px solid transparent; /* To keep it tidy */
  }

  .newsletter-submit svg {
    width: 16px;
    height: 16px;
  }

  .newsletter-success {
    margin-top: 12px;
    color: green;
    font-size: 14px;
    font-weight: 500;
  }

  /* Bottom Bar */
  .footer-bottom {
    padding-top: 40px;
    /* border-top: 1px solid #EDEDED; */ /* Not in screenshot */
    text-align: center;
  }

  .footer-copyright {
    font-size: 12px;
    color: #6C6C6C;
    letter-spacing: 0.02em;
  }

  .footer-copyright a {
    color: inherit;
    text-decoration: none;
  }

  /* Mobile */
  @media screen and (max-width: 768px) {
    .footer-top-grid {
      grid-template-columns: 1fr;
      text-align: left;
      gap: 30px;
    }

    .multivitamin-footer {
      padding: 60px 0 30px;
    }

    .newsletter-heading {
      font-size: 20px;
    }
  }
</style>
